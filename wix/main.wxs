<?xml version="1.0" encoding="UTF-8"?>
<?if $(sys.BUILDARCH) = x64 or $(sys.BUILDARCH) = arm64 ?>
  <?define PlatformProgramFilesFolder = "ProgramFiles64Folder" ?>
<?else ?>
  <?define PlatformProgramFilesFolder = "ProgramFilesFolder" ?>
<?endif ?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="Assinador Livre"
    Language="1046"
    Version="$(var.Version)"
    Manufacturer="Assinador Livre"
    UpgradeCode="1B5C11A4-51D6-4D63-8CE3-8F2A4EAA2A87">

    <Package
      Description="Aplicacao desktop para assinatura digital de PDF com certificado A3 no Windows"
      Manufacturer="Assinador Livre"
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      InstallPrivileges="elevated" />

    <MajorUpgrade
      Schedule="afterInstallInitialize"
      DowngradeErrorMessage="Ja existe uma versao mais recente do [ProductName] instalada." />

    <MediaTemplate EmbedCab="yes" />
    <Icon Id="AppIcon.ico" SourceFile="$(sys.SOURCEFILEDIR)..\assets\icone-assinador-livre.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="$(var.PlatformProgramFilesFolder)" Name="PFiles">
        <Directory Id="APPLICATIONFOLDER" Name="Assinador Livre">
          <Directory Id="Bin" Name="bin">
            <Component Id="MainExecutableComponent" Guid="6D6BC45E-B8E5-47D6-8E62-2D3C2C3C1E13">
              <File
                Id="AssinadorLivreExe"
                Name="assinador-livre-rs.exe"
                Source="$(var.CargoTargetBinDir)\assinador-livre-rs.exe"
                KeyPath="yes" />
            </Component>
          </Directory>
        </Directory>
      </Directory>
    </Directory>

    <Feature
      Id="MainFeature"
      Title="Assinador Livre"
      Description="Aplicacao desktop para assinatura digital de PDF com certificado A3 no Windows"
      Level="1"
      ConfigurableDirectory="APPLICATIONFOLDER"
      AllowAdvertise="no"
      Display="expand"
      Absent="disallow">
      <ComponentRef Id="MainExecutableComponent" />
    </Feature>

    <SetProperty Id="ARPINSTALLLOCATION" Value="[APPLICATIONFOLDER]" After="CostFinalize" />
    <UIRef Id="WixUI_FeatureTree" />
    <UIRef Id="WixUI_ErrorProgressText" />
  </Product>
</Wix>
